<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="DICOM Receiver"
           Manufacturer="Mxyzttlk"
           Version="$(var.ProductVersion)"
           UpgradeCode="5f73e06c-26a7-4dff-8bc9-d5166b31af2d"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="DICOM Receiver — medical imaging study receiver and DVD burn tool" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of DICOM Receiver is already installed."
                  Schedule="afterInstallInitialize"
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- UI: Typical (quick, all features) / Custom (feature checkboxes + directory chooser) -->
    <ui:WixUI Id="WixUI_Mondo" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <Icon Id="AppIcon" SourceFile="$(var.AppPublishDir)Resources\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Mxyzttlk" />

    <!-- .NET 8 Desktop Runtime: detection and install handled by Bundle (Burn bootstrapper).
         No Launch Condition here — the Bundle installs .NET before running this MSI. -->

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DICOM Receiver">
        <Directory Id="SCRIPTS_DIR" Name="scripts" />
        <Directory Id="TEMPLATES_DIR" Name="templates">
          <Directory Id="TUTORIAL_DIR" Name="tutorial" />
        </Directory>
        <Directory Id="RESOURCES_DIR" Name="Resources" />
        <Directory Id="RUNTIMES_DIR" Name="runtimes">
          <Directory Id="RUNTIMES_WIN_DIR" Name="win-x64">
            <Directory Id="RUNTIMES_NATIVE_DIR" Name="native" />
          </Directory>
        </Directory>
        <Directory Id="TOOLS_DIR" Name="tools">
          <Directory Id="WEASIS_DIR" Name="weasis-portable" />
          <Directory Id="DCMTK_DIR" Name="dcmtk" />
          <Directory Id="WEBVIEW2_DIR" Name="webview2" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="DICOM Receiver" />
    </StandardDirectory>

    <!-- Features -->
    <Feature Id="F_Main" Title="DICOM Receiver" Description="Core application and Windows service" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="CG_App" />
      <ComponentGroupRef Id="CG_Service" />
      <ComponentGroupRef Id="CG_Scripts" />
      <ComponentGroupRef Id="CG_Templates" />
      <ComponentRef Id="C_CleanupDirs" />
      <ComponentRef Id="C_CleanupProgramData" />
    </Feature>

    <Feature Id="F_DesktopShortcut" Title="Desktop Shortcut" Description="Create a shortcut on the Desktop" Level="1">
      <ComponentRef Id="C_DesktopShortcut" />
    </Feature>

    <Feature Id="F_StartMenuShortcut" Title="Start Menu Shortcut" Description="Create a shortcut in the Start Menu" Level="1">
      <ComponentRef Id="C_StartMenuShortcut" />
    </Feature>

    <?if $(var.IncludeTools) = true ?>
    <Feature Id="F_Tools" Title="Bundled Tools (Weasis, JRE, dcmtk)" Description="Weasis viewer, JRE, and dcmtk tools (offline)" Level="1">
      <ComponentGroupRef Id="CG_Tools" />
    </Feature>
    <?endif?>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="C_DesktopShortcut" Guid="c5d1e2f3-4a6b-7c8d-9e0f-1a2b3c4d5e6f">
        <Shortcut Id="SC_Desktop"
                  Name="DICOM Receiver"
                  Target="[INSTALLFOLDER]DicomReceiver.exe"
                  Icon="AppIcon"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\DicomReceiver" Name="desktopShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="ProgramMenuDir">
      <Component Id="C_StartMenuShortcut" Guid="a3f8e1d2-7b4c-4a9e-8f3d-2c1b5e6a7d8f">
        <Shortcut Id="SC_App"
                  Name="DICOM Receiver"
                  Target="[INSTALLFOLDER]DicomReceiver.exe"
                  Icon="AppIcon"
                  WorkingDirectory="INSTALLFOLDER" />
        <?if $(var.IncludeTools) != true ?>
        <Shortcut Id="SC_Setup"
                  Name="Download Weasis Tools"
                  Target="[SystemFolder]WindowsPowerShell\v1.0\powershell.exe"
                  Arguments="-ExecutionPolicy Bypass -NoProfile -File &quot;[INSTALLFOLDER]scripts\setup.ps1&quot;"
                  WorkingDirectory="INSTALLFOLDER" />
        <?endif?>
        <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\DicomReceiver" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Cleanup runtime-created directories on uninstall -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="C_CleanupDirs" Guid="b4e9f2c3-8d5a-4b0e-9a4c-3d2e6f7b8c9a" KeyPath="yes">
        <util:RemoveFolderEx On="uninstall" Property="INSTALLFOLDER_PROP" />
      </Component>
    </DirectoryRef>
    <SetProperty Id="INSTALLFOLDER_PROP" Value="[INSTALLFOLDER]" Before="RemoveFiles" Sequence="execute" />

    <!-- Cleanup shared settings (C:\ProgramData\WeasisBurn) on uninstall -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="C_CleanupProgramData" Guid="d6f0a3b4-9e7c-4d1f-8b2a-5c3e7f8a9b0c" KeyPath="yes">
        <util:RemoveFolderEx On="uninstall" Property="PROGRAMDATA_WEASIS_PROP" />
      </Component>
    </DirectoryRef>
    <SetProperty Id="PROGRAMDATA_WEASIS_PROP" Value="[CommonAppDataFolder]WeasisBurn" Before="RemoveFiles" Sequence="execute" />


  </Package>

</Wix>
