<Window x:Class="DicomReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DicomReceiver.ViewModels"
        xmlns:helpers="clr-namespace:DicomReceiver.Helpers"
        xmlns:views="clr-namespace:DicomReceiver.Views"
        Title="{Binding Title}"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Top-right controls — overlays tab header area, always visible -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,4,8,0" Panel.ZIndex="10">
            <Button Content="{Binding ToggleButtonText}"
                    Command="{Binding ToggleScpCommand}"
                    Style="{StaticResource AccentButton}"
                    Width="80" FontSize="12" FontWeight="SemiBold" Padding="4,4" />
            <Button x:Name="BtnSettings"
                    Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource DarkButton}"
                    Padding="8,4" Margin="6,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock x:Name="TxtSettingsLabel" Text="Settings" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

    <TabControl x:Name="MainTabControl" Background="{StaticResource BackgroundBrush}"
                BorderThickness="0" Padding="0"
                SelectionChanged="MainTabControl_SelectionChanged">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="tabBorder" Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                    Padding="{TemplateBinding Padding}" Cursor="Hand">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource BorderBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- Tab 1: DICOM Queue -->
        <TabItem x:Name="TabQueue">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="TxtQueueTab" Text="DICOM Queue" />
                </StackPanel>
            </TabItem.Header>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel>
                <!-- Left: Import + multi-select controls -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Command="{Binding ImportCommand}"
                            Style="{StaticResource DarkButton}"
                            FontSize="13" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock x:Name="TxtImportLabel" Text="Import" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Delete all -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnDeleteAll" Content="Delete All"
                            Command="{Binding DeleteAllCommand}"
                            Style="{StaticResource DarkButton}"
                            FontSize="12" Padding="10,4" />
                </StackPanel>

                <!-- Center: Privacy toggles (multi-select) + Burn Selected + info -->
                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2" />

                    <!-- Anonymize toggle for ALL selected studies (visible when multiple studies selected) -->
                    <Button Command="{Binding ToggleAnonymizeSelectedCommand}"
                            ToolTip="{Binding AnonymizeTooltip}"
                            Width="30" Height="30" Margin="0,0,3,0"
                            Visibility="{Binding HasMultipleSelectedStudies, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse x:Name="bg" Width="26" Height="26"
                                             Fill="{StaticResource SurfaceBrush}"
                                             Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5" />
                                    <TextBlock x:Name="icon" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAnonymizeActive}" Value="True">
                                        <Setter TargetName="bg" Property="Fill" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="icon" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Hide All toggle for ALL selected studies — HIDDEN (use Anonymize instead) -->
                    <Button Command="{Binding ToggleHideAllSelectedCommand}"
                            ToolTip="{Binding HideAllTooltip}"
                            Width="30" Height="30" Margin="0,0,6,0"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Ellipse x:Name="bg" Width="26" Height="26"
                                             Fill="{StaticResource SurfaceBrush}"
                                             Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5" />
                                    <TextBlock x:Name="icon" Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding SelectedHideAllActive}" Value="True">
                                        <Setter TargetName="bg" Property="Fill" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                        <Setter TargetName="icon" Property="Foreground" Value="White" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="{Binding BurnSelectedLabel}"
                            Command="{Binding BurnSelectedCommand}"
                            Style="{StaticResource AccentButton}"
                            FontSize="12" Padding="10,4"
                            IsEnabled="{Binding HasSelectedStudies}" />
                    <TextBlock Text="{Binding SelectedStudiesInfo}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Study Queue -->
        <DataGrid x:Name="StudyGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Studies}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionChanged="StudyGrid_SelectionChanged"
                  Background="{StaticResource BackgroundBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  RowBackground="{StaticResource BackgroundBrush}"
                  AlternatingRowBackground="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  HeadersVisibility="Column"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  FontSize="13"
                  Margin="0">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                    <Setter Property="Padding" Value="8,6" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="12" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,4" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#33FFFFFF" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                    <Setter Property="DetailsVisibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="DetailsVisibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <ItemsControl ItemsSource="{Binding Series}" Margin="40,4,4,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="3" Padding="8,5" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Modality}"
                                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ImageCount, StringFormat='{}{0} img'}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding SizeFormatted}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding SeriesDescription}" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"
                                                   ToolTip="{Binding SeriesInstanceUid}" />
                                        <Button Grid.Column="4" Content="X"
                                                Command="{Binding DataContext.DeleteSeriesCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DarkButton}"
                                                Padding="4,1" FontSize="10" Foreground="#E53935"
                                                Width="24" Height="22" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>

            <DataGrid.Columns>
                <!-- Expand/Collapse toggle -->
                <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ExpandButtonText}"
                                    Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DarkButton}"
                                    Padding="0" FontSize="14" FontWeight="Bold"
                                    Width="24" Height="24" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status indicator -->
                <DataGridTemplateColumn Header="" Width="32" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" HorizontalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#FFA726" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Receiving">
                                                <Setter Property="Fill" Value="#FFA726" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Complete">
                                                <Setter Property="Fill" Value="#0F9B58" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Burning">
                                                <Setter Property="Fill" Value="#2196F3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Done">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                <Setter Property="Fill" Value="#E53935" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn x:Name="ColPatient" Header="Patient" Binding="{Binding PatientName}" Width="200" />
                <DataGridTextColumn x:Name="ColStudyDate" Header="Study Date" Binding="{Binding StudyDate}" Width="100" />
                <DataGridTextColumn x:Name="ColModality" Header="Modality" Binding="{Binding Modality}" Width="80" />
                <DataGridTextColumn x:Name="ColSeries" Header="Series" Binding="{Binding SeriesCount}" Width="60" />
                <DataGridTextColumn x:Name="ColImages" Header="Images" Binding="{Binding ImageCount}" Width="70" />
                <DataGridTextColumn x:Name="ColSize" Header="Size" Binding="{Binding TotalSizeFormatted}" Width="90" />
                <DataGridTextColumn x:Name="ColStatus" Header="Status" Binding="{Binding StatusText}" Width="200" />

                <!-- Action buttons: Privacy toggles (left) + Burn (center) + Delete (right) -->
                <DataGridTemplateColumn Header="" Width="210">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <!-- LEFT: Anonymize + Edit -->
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <!-- Anonymize toggle (circle) per study -->
                                    <Button Command="{Binding DataContext.ToggleAnonymizeStudyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding DataContext.AnonymizeTooltip, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Width="24" Height="24" Margin="0,0,3,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse x:Name="bg" Width="22" Height="22"
                                                             Fill="{StaticResource SurfaceBrush}"
                                                             Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5" />
                                                    <TextBlock x:Name="icon" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnonymizeActive}" Value="True">
                                                        <Setter TargetName="bg" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="icon" Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Hide All toggle (circle) per study — HIDDEN (use Anonymize instead) -->
                                    <Button Command="{Binding DataContext.ToggleHideAllStudyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding DataContext.HideAllTooltip, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Width="24" Height="24" Margin="0,0,3,0"
                                            Visibility="Collapsed">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse x:Name="bg" Width="22" Height="22"
                                                             Fill="{StaticResource SurfaceBrush}"
                                                             Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5" />
                                                    <TextBlock x:Name="icon" Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsHideAllActive}" Value="True">
                                                        <Setter TargetName="bg" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="icon" Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Edit study metadata -->
                                    <Button Command="{Binding DataContext.EditStudyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding DataContext.EditStudyTooltip, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Width="24" Height="24"
                                            IsEnabled="{Binding Status, Converter={StaticResource StatusToBoolConverter}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse x:Name="bg" Width="22" Height="22"
                                                             Fill="{StaticResource SurfaceBrush}"
                                                             Stroke="{StaticResource BorderBrush}" StrokeThickness="1.5" />
                                                    <TextBlock x:Name="icon" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Stroke" Value="{StaticResource AccentHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="icon" Property="Opacity" Value="0.3" />
                                                        <Setter TargetName="bg" Property="Opacity" Value="0.3" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- RIGHT: Delete X -->
                                <Button DockPanel.Dock="Right" Content="X"
                                        Command="{Binding DataContext.DeleteStudyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DarkButton}"
                                        Padding="6,2" FontSize="11" Foreground="#E53935" />

                                <!-- CENTER: Burn (stretches to fill remaining space) -->
                                <Button Content="{Binding DataContext.BurnLabel, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Command="{Binding DataContext.BurnStudyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource AccentButton}"
                                        Padding="8,2" FontSize="11" Margin="6,0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding Status, Converter={StaticResource StatusToBoolConverter}}" />
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}" />

        <!-- Log Panel -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="8,4">
                    <TextBlock x:Name="TxtLogLabel" Text="Log" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button x:Name="BtnClearLog" Content="Clear" Command="{Binding ClearLogCommand}"
                            Style="{StaticResource DarkButton}"
                            FontSize="10" Padding="6,2" HorizontalAlignment="Right" />
                </DockPanel>
                <ListBox ItemsSource="{Binding LogEntries}"
                         Background="Transparent"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         x:Name="LogListBox">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,1" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,4">
            <DockPanel>
                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#E53935" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Fill" Value="#0F9B58" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
        </TabItem>

        <!-- Tab 2: PACS Browser -->
        <TabItem x:Name="TabPacs">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="TxtPacsTab" Text="PACS Browser" />
                </StackPanel>
            </TabItem.Header>
            <views:PacsBrowserView x:Name="PacsBrowserView" />
        </TabItem>
    </TabControl>
    </Grid>
</Window>
