<Window x:Class="DicomReceiver.Views.PacsNetworkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PACS Networks"
        Width="600" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="PACS Networks"
                   Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Network list + Edit form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: list + up/down -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button x:Name="BtnMoveUp" Content="▲" Width="30" Height="26"
                            Style="{StaticResource DarkButton}" Click="BtnMoveUp_Click"
                            Padding="0" FontSize="12" Margin="0,0,4,0" />
                    <Button x:Name="BtnMoveDown" Content="▼" Width="30" Height="26"
                            Style="{StaticResource DarkButton}" Click="BtnMoveDown_Click"
                            Padding="0" FontSize="12" />
                </StackPanel>
                <ListBox x:Name="LstNetworks" SelectionChanged="LstNetworks_SelectionChanged"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#33FFFFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>

            <!-- Right: edit form -->
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="LblName" Text="Name:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="TxtName" Margin="0,0,0,8" Padding="6,4"
                         Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}" />

                <TextBlock x:Name="LblUrl" Text="URL:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="TxtUrl" Margin="0,0,0,8" Padding="6,4"
                         Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}" />

                <TextBlock x:Name="LblUsername" Text="Username:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="TxtUsername" Margin="0,0,0,8" Padding="6,4"
                         Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}" />

                <TextBlock x:Name="LblPassword" Text="Password:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="TxtPassword" Margin="0,0,0,8" Padding="6,4"
                             Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}" />
            </StackPanel>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="BtnAdd" Content="Add" Style="{StaticResource AccentButton}"
                    Padding="12,4" Click="BtnAdd_Click" Margin="0,0,6,0" />
            <Button x:Name="BtnSave" Content="Save" Style="{StaticResource DarkButton}"
                    Padding="12,4" Click="BtnSave_Click" Margin="0,0,6,0" />
            <Button x:Name="BtnDelete" Content="Delete" Style="{StaticResource DarkButton}"
                    Padding="12,4" Click="BtnDelete_Click" Foreground="#E53935" />
        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnOK" Content="OK" Style="{StaticResource AccentButton}"
                    Padding="20,6" Click="BtnOK_Click" IsDefault="True" />
            <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource DarkButton}"
                    Padding="20,6" Click="BtnCancel_Click" IsCancel="True" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
