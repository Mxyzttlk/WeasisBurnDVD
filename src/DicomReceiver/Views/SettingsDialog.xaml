<Window x:Class="DicomReceiver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="SettingsWindow"
        Width="500" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- AE Title -->
        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblAeTitle" Text="AE Title:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtAeTitle"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" />

        <!-- Port -->
        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblPort" Text="Port:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPort"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" />

        <!-- Incoming Folder -->
        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblIncomingFolder" Text="Incoming Folder:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="..." Click="BrowseFolder_Click"
                    Style="{StaticResource DarkButton}" Padding="8,4" Margin="6,0,0,0" />
            <TextBox x:Name="TxtIncomingFolder"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="13" />
        </DockPanel>

        <!-- Study Timeout -->
        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblTimeout" Text="Study Timeout (sec):" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtTimeout"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" Width="80" HorizontalAlignment="Left" />

        <!-- DVD Writer -->
        <TextBlock Grid.Row="4" Grid.Column="0" x:Name="LblDriveWriter" Text="DVD Writer:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" x:Name="BtnRefreshDrives" Content="&#x21BB;" Click="RefreshDrives_Click"
                    Style="{StaticResource DarkButton}" Padding="8,4" Margin="6,0,0,0" FontSize="14" />
            <ComboBox x:Name="CmbDriveWriter" />
        </DockPanel>

        <!-- Burn Speed -->
        <TextBlock Grid.Row="5" Grid.Column="0" x:Name="LblBurnSpeed" Text="Burn Speed:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="CmbBurnSpeed"
                  Margin="0,0,0,10" Width="80" HorizontalAlignment="Left">
            <ComboBoxItem Content="2x" Tag="2" />
            <ComboBoxItem Content="4x" Tag="4" />
            <ComboBoxItem Content="8x" Tag="8" />
            <ComboBoxItem Content="12x" Tag="12" />
            <ComboBoxItem Content="16x" Tag="16" />
        </ComboBox>

        <!-- Language -->
        <TextBlock Grid.Row="6" Grid.Column="0" x:Name="LblLanguage" Text="Language:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="CmbLanguage"
                  Margin="0,0,0,10" Width="150" HorizontalAlignment="Left">
            <ComboBoxItem Content="Auto-detect" Tag="auto" />
            <ComboBoxItem Content="Romanian" Tag="ro" />
            <ComboBoxItem Content="Russian" Tag="ru" />
            <ComboBoxItem Content="English" Tag="en" />
        </ComboBox>

        <!-- Auto-delete after burn -->
        <TextBlock Grid.Row="7" Grid.Column="0" x:Name="LblAutoDelete" Text="Auto-delete:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <CheckBox Grid.Row="7" Grid.Column="1" x:Name="ChkAutoDelete"
                  Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                  Margin="0,0,0,10" FontSize="13"
                  Checked="ChkAutoDelete_Changed" Unchecked="ChkAutoDelete_Changed" />

        <!-- Max studies keep (disabled when AutoDelete is ON — mutually exclusive) -->
        <TextBlock Grid.Row="8" Grid.Column="0" x:Name="LblMaxStudies" Text="Max studies:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <StackPanel Grid.Row="8" Grid.Column="1" x:Name="PnlMaxStudies" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="TxtMaxStudies"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="13" Width="80" />
            <TextBlock x:Name="LblMaxStudiesHint" Text="  (0 = unlimited)" VerticalAlignment="Center"
                       Foreground="#888" FontSize="12" />
        </StackPanel>

        <!-- PACS Browser section -->
        <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="LblPacsSection" Text="PACS Browser"
                   Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold"
                   Margin="0,6,0,8" VerticalAlignment="Bottom" />

        <!-- Auto-Login -->
        <TextBlock Grid.Row="10" Grid.Column="0" x:Name="LblAutoLogin" Text="Auto-Login:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <CheckBox Grid.Row="10" Grid.Column="1" x:Name="ChkAutoLogin"
                  Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                  Margin="0,0,0,10" FontSize="13" />

        <!-- Auto-Unlock -->
        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="LblAutoUnlock" Text="Auto-Unlock:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <CheckBox Grid.Row="11" Grid.Column="1" x:Name="ChkAutoUnlock"
                  Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                  Margin="0,0,0,10" FontSize="13" />

        <!-- Auto Exclude Viewer -->
        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="LblAutoExcludeViewer" Text="Auto Exclude Viewer:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <CheckBox Grid.Row="12" Grid.Column="1" x:Name="ChkAutoExcludeViewer"
                  Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                  Margin="0,0,0,10" FontSize="13" />

        <!-- Simulate Only -->
        <TextBlock Grid.Row="13" Grid.Column="0" x:Name="LblSimulateOnly" Text="Simulate:" VerticalAlignment="Center"
                   Foreground="#FFA500" Margin="0,0,0,10" />
        <CheckBox Grid.Row="13" Grid.Column="1" x:Name="ChkSimulateOnly"
                  Foreground="#FFA500" VerticalAlignment="Center"
                  Margin="0,0,0,10" FontSize="13" />

        <!-- Edit Networks -->
        <TextBlock Grid.Row="14" Grid.Column="0" x:Name="LblEditNetworks" Text="Networks:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <Button Grid.Row="14" Grid.Column="1" x:Name="BtnEditNetworks" Content="Edit Networks..."
                Click="EditNetworks_Click" Style="{StaticResource DarkButton}"
                Width="150" HorizontalAlignment="Left" Margin="0,0,0,10" />

        <!-- Buttons -->
        <StackPanel Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnRestartService" Content="Restart Service" Click="RestartService_Click"
                    Style="{StaticResource DarkButton}" Width="130" Margin="0,0,8,0" />
            <Button x:Name="BtnCancel" Content="Cancel" Click="Cancel_Click"
                    Style="{StaticResource DarkButton}" Width="90" Margin="0,0,8,0" />
            <Button x:Name="BtnSave" Content="Save" Click="Save_Click"
                    Style="{StaticResource AccentButton}" Width="90" />
        </StackPanel>
    </Grid>
</Window>
