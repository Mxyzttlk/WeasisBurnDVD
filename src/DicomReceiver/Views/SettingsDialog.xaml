<Window x:Class="DicomReceiver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="500" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- AE Title -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="AE Title:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtAeTitle"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" />

        <!-- Port -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPort"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" />

        <!-- Incoming Folder -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Incoming Folder:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="..." Click="BrowseFolder_Click"
                    Style="{StaticResource DarkButton}" Padding="8,4" Margin="6,0,0,0" />
            <TextBox x:Name="TxtIncomingFolder"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="13" />
        </DockPanel>

        <!-- Study Timeout -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Study Timeout (sec):" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtTimeout"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" Width="80" HorizontalAlignment="Left" />

        <!-- Burn Speed -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Burn Speed:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbBurnSpeed"
                  Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                  BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" Width="80" HorizontalAlignment="Left">
            <ComboBoxItem Content="2x" Tag="2" />
            <ComboBoxItem Content="4x" Tag="4" />
            <ComboBoxItem Content="8x" Tag="8" />
        </ComboBox>

        <!-- Language -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Language:" VerticalAlignment="Center"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" />
        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="CmbLanguage"
                  Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                  BorderBrush="{StaticResource BorderBrush}" Padding="6,4" Margin="0,0,0,10" FontSize="13" Width="150" HorizontalAlignment="Left">
            <ComboBoxItem Content="Auto-detect" Tag="auto" />
            <ComboBoxItem Content="Romanian" Tag="ro" />
            <ComboBoxItem Content="Russian" Tag="ru" />
            <ComboBoxItem Content="English" Tag="en" />
        </ComboBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Style="{StaticResource DarkButton}" Width="90" Margin="0,0,8,0" />
            <Button Content="Save" Click="Save_Click"
                    Style="{StaticResource AccentButton}" Width="90" />
        </StackPanel>
    </Grid>
</Window>
