<Window x:Class="DicomReceiver.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Width="460" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Icon + Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Image x:Name="AppIcon" Width="48" Height="48" Margin="0,0,14,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtAppName" Text="DICOM Receiver" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock x:Name="TxtVersion" Text="v1.0.0" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Copyright -->
            <TextBlock Grid.Row="1" x:Name="TxtCopyright"
                       Text="Copyright (c) 2026 Mxyzttlk. All rights reserved."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />

            <!-- License -->
            <TextBlock Grid.Row="2" x:Name="TxtLicense"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />

            <!-- GitHub -->
            <TextBlock Grid.Row="3" Margin="0,0,0,14">
                <Hyperlink x:Name="LinkGithub" NavigateUri="https://github.com/Mxyzttlk"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{StaticResource AccentBrush}" TextDecorations="None">
                    <Run Text="github.com/Mxyzttlk" />
                </Hyperlink>
            </TextBlock>

            <!-- Third-party components -->
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="12,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="TxtComponentsHeader" Text="Open Source Components" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" />
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"
                                   TextWrapping="Wrap" LineHeight="18">
                            <Run Text="Weasis 3.7.1" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — EPL-2.0 / Apache-2.0" /><LineBreak />
                            <Run Text="Adoptium JRE 8" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — GPL-2.0 + Classpath Ex." /><LineBreak />
                            <Run Text="fo-dicom 5.1.3" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — MS-PL" /><LineBreak />
                            <Run Text="Apache Felix" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — Apache-2.0" /><LineBreak />
                            <Run Text="CommunityToolkit.Mvvm" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — MIT" /><LineBreak />
                            <Run Text="WebView2 SDK" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — MIT" /><LineBreak />
                            <Run Text="dcmtk 3.7.0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <Run Text=" — BSD" />
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Close button -->
            <Button Grid.Row="5" x:Name="BtnClose" Content="OK"
                    Style="{StaticResource AccentButton}"
                    Width="90" HorizontalAlignment="Right" Margin="0,14,0,0"
                    Padding="8,6" FontSize="13"
                    Click="BtnClose_Click" IsDefault="True" />
        </Grid>
    </Border>
</Window>
